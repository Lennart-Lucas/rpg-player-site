---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../../layouts/Layout.astro';
import LocationTreeList from '../../../components/LocationTreeList.astro';
import type { LocationNodeData } from '../../../components/LocationNode.astro';
import {
  htmlForRecord,
  type LocationIndexEntry,
} from '../../../lib/recordRender';
import { applyInlineMarkdownHtml, formatCardBodyHtml } from '../../../lib/cardBodyHtml';
import {
  conditionAccentHex,
  conditionIconSvg,
  conditionRarityLabel,
  darkenHex,
  readableForeground,
} from '../../../lib/conditionVisuals';
import {
  itemRarityLabel,
  itemSubtitleText,
  itemTypeIconSvg,
  itemTypeLabel,
  suggestedGoldRangeForRarity,
} from '../../../lib/itemVisuals';
import {
  spellCastingAndRangeText,
  spellComponentsLine,
  spellDurationCardDisplay,
  spellHeaderSummary,
  spellSchoolIconSvg,
} from '../../../lib/spellVisuals';

type LocationTreeNode = {
  item: LocationIndexEntry;
  children: LocationTreeNode[];
};

export function getStaticPaths() {
  const recordsRoot = path.join(
    process.cwd(),
    'public',
    'rpg-export',
    'records',
  );
  if (!fs.existsSync(recordsRoot)) return [];

  const paths: { params: { recordType: string; recordId: string } }[] = [];
  for (const recordType of fs.readdirSync(recordsRoot)) {
    const typeDir = path.join(recordsRoot, recordType);
    if (!fs.statSync(typeDir).isDirectory()) continue;
    for (const file of fs.readdirSync(typeDir)) {
      if (!file.endsWith('.json')) continue;
      const recordId = file.replace(/\.json$/, '');
      paths.push({ params: { recordType, recordId } });
    }
  }
  return paths;
}

const locationTypeLabels: Record<string, string> = {
  continent: 'Continent',
  nation: 'Nation',
  region: 'Region',
  city: 'City',
  village: 'Village',
  district: 'District',
  building: 'Building',
  dungeon: 'Dungeon',
  cave: 'Cave',
  landmark: 'Landmark',
  other: 'Other',
};

function displayLocationType(code: string): string {
  return locationTypeLabels[code] ?? code;
}

function stringArray(raw: unknown): string[] {
  if (!Array.isArray(raw)) return [];
  return raw
    .map((v) => (typeof v === 'string' ? v.trim() : ''))
    .filter((v) => v.length > 0);
}

function loadLocationIndex(): LocationIndexEntry[] {
  const indexPath = path.join(
    process.cwd(),
    'public',
    'rpg-export',
    'locations-index.json',
  );
  try {
    const raw = fs.readFileSync(indexPath, 'utf8');
    const parsed = JSON.parse(raw) as { items?: LocationIndexEntry[] };
    if (!Array.isArray(parsed.items)) return [];
    return parsed.items.filter(
      (i) =>
        i &&
        typeof i.id === 'string' &&
        i.id.length > 0 &&
        typeof i.name === 'string',
    );
  } catch {
    return [];
  }
}

function buildDescendantTree(
  items: LocationIndexEntry[],
  rootId: string,
): LocationTreeNode[] {
  const ids = new Set(items.map((r) => r.id));
  const byParent = new Map<string | null, LocationIndexEntry[]>();
  for (const row of items) {
    const p =
      typeof row.parentLocationId === 'string' &&
      row.parentLocationId.trim().length > 0 &&
      ids.has(row.parentLocationId)
        ? row.parentLocationId
        : null;
    const list = byParent.get(p) ?? [];
    list.push(row);
    byParent.set(p, list);
  }
  for (const list of byParent.values()) {
    list.sort((a, b) =>
      a.name.localeCompare(b.name, undefined, { sensitivity: 'base' }),
    );
  }
  function walk(parent: string): LocationTreeNode[] {
    const list = byParent.get(parent) ?? [];
    return list.map((item) => ({ item, children: walk(item.id) }));
  }
  return walk(rootId);
}

function subtitleFor(
  item: LocationIndexEntry,
  byId: Map<string, LocationIndexEntry>,
): string {
  const type = displayLocationType(item.locationType);
  const parentId = item.parentLocationId;
  if (
    parentId &&
    typeof parentId === 'string' &&
    parentId.trim().length > 0 &&
    byId.has(parentId.trim())
  ) {
    return `${type} \u00b7 in ${byId.get(parentId.trim())!.name}`;
  }
  return type;
}

function toLocationNodeDataList(
  nodes: LocationTreeNode[],
  byId: Map<string, LocationIndexEntry>,
): LocationNodeData[] {
  return nodes.map((n) => ({
    id: n.item.id,
    name: n.item.name,
    href: `/records/location/${encodeURIComponent(n.item.id)}/`,
    subtitle: subtitleFor(n.item, byId),
    children: toLocationNodeDataList(n.children, byId),
  }));
}

const { recordType, recordId } = Astro.params;
const file = path.join(
  process.cwd(),
  'public',
  'rpg-export',
  'records',
  recordType!,
  `${recordId!}.json`,
);

if (!fs.existsSync(file)) {
  return Astro.redirect('/unpublished/');
}

const payload = JSON.parse(fs.readFileSync(file, 'utf8')) as {
  data: Record<string, unknown>;
};

let locationIndexItems: LocationIndexEntry[] = [];
let locationIndexById: Map<string, LocationIndexEntry> | undefined;
if (recordType === 'location') {
  locationIndexItems = loadLocationIndex();
  locationIndexById = new Map(locationIndexItems.map((i) => [i.id, i]));
}

function playerSiteRecordJsonExists(
  recordType: string,
  recordId: string,
): boolean {
  if (!/^[a-zA-Z0-9_-]+$/.test(recordType)) return false;
  if (!/^[a-zA-Z0-9_-]+$/.test(recordId)) return false;
  const p = path.join(
    process.cwd(),
    'public',
    'rpg-export',
    'records',
    recordType,
    `${recordId}.json`,
  );
  return fs.existsSync(p);
}

const isCondition = recordType === 'condition';
const isItem = recordType === 'item';
const isSpell = recordType === 'spell';
const body =
  isCondition || isItem || isSpell
    ? ''
    : htmlForRecord(recordType!, payload.data, {
        locationIndexById,
        recordJsonExists: playerSiteRecordJsonExists,
      });
const title =
  (typeof payload.data.name === 'string' && payload.data.name) ||
  (typeof payload.data.title === 'string' && payload.data.title) ||
  recordId!;

let childLocationRoots: LocationNodeData[] = [];
if (recordType === 'location' && typeof recordId === 'string' && locationIndexById) {
  const subtree = buildDescendantTree(locationIndexItems, recordId);
  if (subtree.length > 0) {
    childLocationRoots = toLocationNodeDataList(subtree, locationIndexById);
  }
}

let conditionView: {
  accent: string;
  darker: string;
  fg: string;
  rarityLabel: string;
  iconSvg: string;
  descriptionHtml: string;
  displayName: string;
} | null = null;
if (isCondition) {
  const data = payload.data;
  const colorRaw = typeof data.color === 'string' ? data.color : '';
  const iconRaw = typeof data.icon === 'string' ? data.icon : '';
  const rarityRaw = typeof data.rarity === 'string' ? data.rarity : '';
  const nameRaw = typeof data.name === 'string' ? data.name.trim() : '';
  const descriptionHtml =
    typeof data.description === 'string' ? data.description : '';
  const accent = conditionAccentHex(colorRaw);
  conditionView = {
    accent,
    darker: darkenHex(accent, 0.12),
    fg: readableForeground(accent),
    rarityLabel: conditionRarityLabel(rarityRaw),
    iconSvg: conditionIconSvg(iconRaw, nameRaw),
    descriptionHtml: formatCardBodyHtml(descriptionHtml),
    displayName: nameRaw.length > 0 ? nameRaw : 'Condition',
  };
}

let itemView: {
  displayName: string;
  itemTypeLabel: string;
  itemTypeIconSvg: string;
  subtitle: string;
  typeReferenceHtml: string;
  rarityLabel: string;
  goldRangeText: string;
  descriptionHtml: string;
} | null = null;
if (isItem) {
  const data = payload.data;
  const nameRaw = typeof data.name === 'string' ? data.name.trim() : '';
  const itemTypeRaw =
    typeof data.itemType === 'string' ? (data.itemType as string) : '';
  const rarityRaw = typeof data.rarity === 'string' ? (data.rarity as string) : '';
  const descriptionHtml =
    typeof data.description === 'string' ? (data.description as string) : '';
  const typeReferenceHtml =
    typeof data.typeReference === 'string'
      ? (data.typeReference as string)
      : '';
  const magic = data.magic === true;
  const consumable = data.consumable === true;
  const requiresAttunement = magic && data.requiresAttunement === true;
  itemView = {
    displayName: nameRaw.length > 0 ? nameRaw : 'Item',
    itemTypeLabel: itemTypeLabel(itemTypeRaw),
    itemTypeIconSvg: itemTypeIconSvg(itemTypeRaw),
    subtitle: itemSubtitleText({
      rarity: rarityRaw,
      magic,
      consumable,
      requiresAttunement,
    }),
    typeReferenceHtml,
    rarityLabel: itemRarityLabel(rarityRaw),
    goldRangeText: suggestedGoldRangeForRarity(rarityRaw),
    descriptionHtml,
  };
}

let spellView: {
  displayName: string;
  schoolIconSvg: string;
  summary: string;
  castingText: string;
  durationText: string;
  componentsText: string;
  descriptionHtml: string;
  higherLevelsHtml: string;
  classNames: string[];
} | null = null;
if (isSpell) {
  const data = payload.data;
  const nameRaw = typeof data.name === 'string' ? data.name.trim() : '';
  const levelRaw = typeof data.level === 'string' ? data.level : '';
  const schoolRaw = typeof data.school === 'string' ? data.school : '';
  const tagNames = stringArray(data.tagNames);
  const classNames = stringArray(data.classNames);
  const castingTime =
    typeof data.castingTime === 'number' ? data.castingTime : 0;
  const castingTypeRaw =
    typeof data.castingType === 'string' ? data.castingType : '';
  const reactionTriggerRaw =
    typeof data.reactionTrigger === 'string' ? data.reactionTrigger : '';
  const rangeRaw = typeof data.spellRange === 'string' ? data.spellRange : '';
  const durationRaw =
    typeof data.spellDuration === 'string' ? data.spellDuration : '';
  const components = stringArray(data.components);
  const materialDescription =
    typeof data.materialDescription === 'string'
      ? data.materialDescription
      : '';
  spellView = {
    displayName: nameRaw.length > 0 ? nameRaw : 'Spell',
    schoolIconSvg: spellSchoolIconSvg(schoolRaw),
    summary: spellHeaderSummary({
      level: levelRaw,
      school: schoolRaw,
      tagNames,
    }),
    castingText: spellCastingAndRangeText({
      castingTime,
      castingType: castingTypeRaw,
      reactionTrigger: reactionTriggerRaw,
      range: rangeRaw,
    }),
    durationText: spellDurationCardDisplay({
      duration: durationRaw,
      concentration: data.concentration === true,
    }),
    componentsText: spellComponentsLine(components, materialDescription),
    descriptionHtml: formatCardBodyHtml(
      typeof data.description === 'string' ? data.description : '',
    ),
    higherLevelsHtml: (() => {
      const higher =
        typeof data.forHigherLevels === 'string'
          ? data.forHigherLevels.trim()
          : '';
      if (!higher) return '';
      return `<strong>At Higher Levels:</strong> ${applyInlineMarkdownHtml(higher)}`;
    })(),
    classNames,
  };
}
---
<Layout title={title} shell shellPath={Astro.url.pathname}>
  {
    conditionView ? (
      <article
        class="condition-card"
        style={`--condition-accent: ${conditionView.accent};`}
      >
        <header
          class="condition-header"
          style={`background: ${conditionView.accent}; color: ${conditionView.fg};`}
        >
          <h1 class="condition-header-name">{conditionView.displayName}</h1>
        </header>
        <div
          class="condition-subband"
          style={`background: ${conditionView.darker}; color: ${conditionView.fg};`}
        >
          <span
            class="condition-subband-icon"
            set:html={conditionView.iconSvg}
          />
          <span class="condition-subband-rarity">
            {conditionView.rarityLabel}
          </span>
        </div>
        <div class="condition-body">
          <div
            class="condition-watermark"
            set:html={conditionView.iconSvg}
            aria-hidden="true"
          />
          <div
            class="condition-description prose"
            set:html={conditionView.descriptionHtml}
          />
        </div>
      </article>
    ) : itemView ? (
      <article class="item-card-detail">
        <header class="item-detail-header">
          <h1 class="item-detail-name">{itemView.displayName}</h1>
        </header>
        <div class="item-detail-subband">
          <span
            class="item-detail-subband-icon"
            set:html={itemView.itemTypeIconSvg}
          />
          <span class="item-detail-subband-text">
            <span class="item-detail-subband-type">
              {itemView.itemTypeLabel}
            </span>
            {itemView.typeReferenceHtml && (
              <span
                class="item-detail-subband-ref"
                set:html={itemView.typeReferenceHtml}
              />
            )}
            <span class="item-detail-subband-summary">{itemView.subtitle}</span>
          </span>
        </div>
        <div class="item-detail-body">
          <div
            class="item-detail-watermark"
            set:html={itemView.itemTypeIconSvg}
            aria-hidden="true"
          />
          <div
            class="item-detail-description prose"
            set:html={itemView.descriptionHtml}
          />
        </div>
        <footer class="item-detail-footer">
          <span class="item-detail-footer-coin" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7v10" />
              <path d="M9 9h6" />
              <path d="M9 15h6" />
            </svg>
          </span>
          <span class="item-detail-footer-text">
            {itemView.rarityLabel}
            {itemView.goldRangeText &&
              ` \u00b7 ${itemView.goldRangeText}`}
          </span>
        </footer>
      </article>
    ) : spellView ? (
      <article class="spell-card">
        <header class="spell-header">
          <h1 class="spell-header-name">{spellView.displayName}</h1>
        </header>
        <div class="spell-subband">
          <span
            class="spell-subband-icon"
            set:html={spellView.schoolIconSvg}
          />
          <span class="spell-subband-summary">{spellView.summary}</span>
        </div>
        <div class="spell-mechanics">
          <div class="spell-mechanics-row">
            <span class="spell-mechanics-label">Casting</span>
            <span class="spell-mechanics-value">{spellView.castingText}</span>
          </div>
          <div class="spell-mechanics-row">
            <span class="spell-mechanics-label">Duration</span>
            <span class="spell-mechanics-value">{spellView.durationText}</span>
          </div>
          <div class="spell-mechanics-row">
            <span class="spell-mechanics-label">Components</span>
            <span class="spell-mechanics-value">
              {spellView.componentsText}
            </span>
          </div>
        </div>
        <div class="spell-body">
          <div
            class="spell-watermark"
            set:html={spellView.schoolIconSvg}
            aria-hidden="true"
          />
          <div
            class="spell-description prose"
            set:html={spellView.descriptionHtml}
          />
          {spellView.higherLevelsHtml && (
            <p
              class="spell-higher-levels prose"
              set:html={spellView.higherLevelsHtml}
            />
          )}
        </div>
        {spellView.classNames.length > 0 && (
          <footer class="spell-footer">
            <span class="spell-footer-icon" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 3 4.5 8.5V20a1 1 0 0 0 1 1H10v-6h4v6h4.5a1 1 0 0 0 1-1V8.5Z" />
                <path d="M9 14h6" />
              </svg>
            </span>
            <span class="spell-footer-text">
              {spellView.classNames.join(', ')}
            </span>
          </footer>
        )}
      </article>
    ) : (
      <article set:html={body} />
    )
  }
  {
    childLocationRoots.length > 0 && (
      <section class="detail-outlined">
        <div class="detail-outlined-tab">Child locations</div>
        <div class="detail-outlined-body">
          <LocationTreeList roots={childLocationRoots} />
        </div>
      </section>
    )
  }
</Layout>

<style is:global>
  /* Location detail (mirrors app overview + flowing body) */
  .location-detail-page {
    --loc-outline: var(--border);
    --loc-surface-low: rgba(255, 255, 255, 0.04);
    --loc-surface-high: rgba(255, 255, 255, 0.07);
    --loc-surface-dim: rgba(255, 255, 255, 0.055);
    --loc-label-bg: rgba(255, 255, 255, 0.08);
    --loc-value-bg: rgba(255, 255, 255, 0.02);
  }
  .location-detail-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .loc-body {
    min-width: 0;
  }
  .loc-page-lead {
    margin: 0 0 0.65rem;
    text-align: start;
  }
  .loc-page-name {
    margin: 0;
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--fg);
    letter-spacing: -0.02em;
  }
  @media (min-width: 540px) {
    .location-detail-grid {
      display: grid;
      grid-template-columns: 1fr min(320px, 34%);
      gap: 0 1rem;
      align-items: start;
    }
    .loc-body {
      grid-column: 1;
      grid-row: 1;
      min-width: 0;
    }
    .loc-overview {
      grid-column: 2;
      grid-row: 1;
    }
  }
  .loc-overview-inner {
    box-sizing: border-box;
    background: var(--loc-surface-low);
    border: 1px solid var(--loc-outline);
    border-radius: 10px;
    padding: 0.65rem;
  }
  .loc-overview-head {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 0.35rem 0.35rem 0.65rem;
  }
  .loc-overview-icon {
    flex: 0 0 auto;
    width: 46px;
    height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    border: 1px solid var(--loc-outline);
    background: var(--loc-surface-high);
    color: var(--muted);
  }
  .loc-pin {
    width: 1.35rem;
    height: 1.35rem;
    display: block;
  }
  .loc-overview-titles {
    flex: 1 1 auto;
    min-width: 0;
  }
  .loc-overview-name {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--fg);
  }
  .loc-overview-aliases {
    margin: 0.25rem 0 0;
    font-size: 0.82rem;
    line-height: 1.35;
    color: var(--muted);
  }
  .loc-overview-media {
    height: 190px;
    border-top: 1px solid color-mix(in srgb, var(--loc-outline) 70%, transparent);
    border-bottom: 1px solid
      color-mix(in srgb, var(--loc-outline) 70%, transparent);
    background: rgba(0, 0, 0, 0.2);
    overflow: hidden;
  }
  .loc-overview-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .loc-overview-media--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .loc-overview-ph-inner {
    text-align: center;
    color: var(--muted);
    padding: 0.5rem;
  }
  .loc-overview-ph-inner .loc-pin {
    margin: 0 auto 0.35rem;
    opacity: 0.85;
  }
  .loc-overview-ph-title {
    font-size: 0.9rem;
    font-weight: 600;
  }
  .loc-overview-ph-sub {
    margin-top: 0.2rem;
    font-size: 0.8rem;
    max-width: 16rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .loc-meta {
    margin-top: 0.35rem;
    border: 1px solid var(--loc-outline);
    border-radius: 8px;
    overflow: hidden;
    background: var(--loc-surface-high);
  }
  .loc-band {
    background: var(--loc-surface-dim);
  }
  .loc-band--divider {
    border-top: 1px solid var(--loc-outline);
  }
  .loc-band-inner {
    padding: 0.65rem 0.75rem 0.5rem;
  }
  .loc-band-title {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg);
  }
  .loc-band .loc-band-inner {
    border-bottom: 1px solid var(--loc-outline);
  }
  .loc-otable {
    background: var(--loc-value-bg);
  }
  .loc-orow {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
    align-items: stretch;
  }
  .loc-orow + .loc-orow {
    border-top: 1px solid var(--loc-outline);
  }
  .loc-olabel {
    background: var(--loc-label-bg);
    padding: 0.45rem 0.6rem;
    text-align: right;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--link);
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }
  .loc-ovalue {
    padding: 0.45rem 0.6rem;
    font-size: 0.88rem;
    line-height: 1.4;
    color: var(--fg);
    display: flex;
    align-items: center;
  }
  .loc-ovalue a {
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .loc-quote {
    margin: 0 0 0.75rem;
    padding: 0;
    border: none;
  }
  .loc-quote-text {
    margin: 0;
    padding: 0.35rem 0 0.35rem 0.85rem;
    border-left: 3px solid var(--link);
    font-style: italic;
    color: color-mix(in srgb, var(--fg) 92%, var(--muted));
  }
  .loc-quote-author {
    margin: 0.4rem 0 0;
    padding-left: 0.85rem;
    font-size: 0.88rem;
    font-style: normal;
    color: var(--muted);
  }
  .loc-sec {
    padding: 0.35rem 0 0.5rem;
    margin-bottom: 0.15rem;
  }
  .loc-sec-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
    color: var(--fg);
  }
  .loc-sec-body {
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .loc-download {
    margin-top: 1rem;
  }
  .loc-download-h {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--muted);
  }

  .detail-outlined {
    position: relative;
    margin-top: 1.35rem;
    padding-top: 0.5rem;
  }
  .detail-outlined-tab {
    display: inline-block;
    margin-left: 0.65rem;
    padding: 0.15rem 0.4rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--fg);
  }
  .detail-outlined-body {
    margin-top: 0.2rem;
