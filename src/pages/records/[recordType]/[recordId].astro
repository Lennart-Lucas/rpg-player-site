---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../../layouts/Layout.astro';
import { htmlForRecord } from '../../../lib/recordRender';

export function getStaticPaths() {
  const recordsRoot = path.join(
    process.cwd(),
    'public',
    'rpg-export',
    'records',
  );
  if (!fs.existsSync(recordsRoot)) return [];

  const paths: { params: { recordType: string; recordId: string } }[] = [];
  for (const recordType of fs.readdirSync(recordsRoot)) {
    const typeDir = path.join(recordsRoot, recordType);
    if (!fs.statSync(typeDir).isDirectory()) continue;
    for (const file of fs.readdirSync(typeDir)) {
      if (!file.endsWith('.json')) continue;
      const recordId = file.replace(/\.json$/, '');
      paths.push({ params: { recordType, recordId } });
    }
  }
  return paths;
}

const { recordType, recordId } = Astro.params;
const file = path.join(
  process.cwd(),
  'public',
  'rpg-export',
  'records',
  recordType!,
  `${recordId!}.json`,
);

if (!fs.existsSync(file)) {
  return Astro.redirect('/unpublished/');
}

const payload = JSON.parse(fs.readFileSync(file, 'utf8')) as {
  data: Record<string, unknown>;
};
const body = htmlForRecord(recordType!, payload.data);
const title =
  (typeof payload.data.name === 'string' && payload.data.name) ||
  (typeof payload.data.title === 'string' && payload.data.title) ||
  recordId!;
---
<Layout title={title}>
  <article set:html={body} />
  <p style="margin-top:2rem"><a href="/">Home</a></p>
</Layout>
