---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../../layouts/Layout.astro';
import LocationTreeList from '../../../components/LocationTreeList.astro';
import type { LocationNodeData } from '../../../components/LocationNode.astro';

type IndexItem = {
  id: string;
  name: string;
  locationType: string;
  parentLocationId: string | null;
};

const indexPath = path.join(
  process.cwd(),
  'public',
  'rpg-export',
  'locations-index.json',
);

let items: IndexItem[] = [];
try {
  const raw = fs.readFileSync(indexPath, 'utf8');
  const parsed = JSON.parse(raw) as { items?: IndexItem[] };
  if (Array.isArray(parsed.items)) {
    items = parsed.items.filter(
      (i) =>
        i &&
        typeof i.id === 'string' &&
        i.id.length > 0 &&
        typeof i.name === 'string',
    );
  }
} catch {
  items = [];
}

const locationTypeLabels: Record<string, string> = {
  continent: 'Continent',
  nation: 'Nation',
  region: 'Region',
  city: 'City',
  village: 'Village',
  district: 'District',
  building: 'Building',
  dungeon: 'Dungeon',
  cave: 'Cave',
  landmark: 'Landmark',
  other: 'Other',
};

function displayType(code: string): string {
  return locationTypeLabels[code] ?? code;
}

const byId = new Map(items.map((i) => [i.id, i]));

function subtitleFor(item: IndexItem): string {
  const type = displayType(item.locationType);
  const parentId = item.parentLocationId;
  if (parentId && byId.has(parentId)) {
    return `${type} \u00b7 in ${byId.get(parentId)!.name}`;
  }
  return type;
}

function buildTree(rows: IndexItem[]): LocationNodeData[] {
  const ids = new Set(rows.map((r) => r.id));
  const byParent = new Map<string | null, IndexItem[]>();
  for (const row of rows) {
    const p =
      row.parentLocationId &&
      typeof row.parentLocationId === 'string' &&
      row.parentLocationId.trim().length > 0 &&
      ids.has(row.parentLocationId)
        ? row.parentLocationId
        : null;
    const list = byParent.get(p) ?? [];
    list.push(row);
    byParent.set(p, list);
  }
  for (const list of byParent.values()) {
    list.sort((a, b) =>
      a.name.localeCompare(b.name, undefined, { sensitivity: 'base' }),
    );
  }
  function walk(parent: string | null): LocationNodeData[] {
    const list = byParent.get(parent) ?? [];
    return list.map((item) => ({
      id: item.id,
      name: item.name,
      href: `/records/location/${encodeURIComponent(item.id)}/`,
      subtitle: subtitleFor(item),
      children: walk(item.id),
    }));
  }
  return walk(null);
}

const roots = buildTree(items);
---
<Layout title="Locations" shell shellPath={Astro.url.pathname}>
  <h1 class="record-title">Locations</h1>
  {
    items.length === 0 ? (
      <p class="meta">
        No published locations yet… Players only see locations you mark as
        published in RPG Manager.
      </p>
    ) : (
      <LocationTreeList roots={roots} />
    )
  }
</Layout>
