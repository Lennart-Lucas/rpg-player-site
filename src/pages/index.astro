---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';

const root = path.join(process.cwd(), 'public', 'rpg-export');
const indexPath = path.join(root, 'index.json');
let home: { recordType: string; recordId: string } | null = null;
let exportedAt: string | null = null;
let entryCount = 0;
try {
  const raw = JSON.parse(fs.readFileSync(indexPath, 'utf8')) as {
    home?: { recordType: string; recordId: string } | null;
    exportedAt?: string | null;
    entries?: { recordType: string; recordId: string }[];
  };
  home = raw.home ?? null;
  exportedAt = raw.exportedAt ?? null;
  entryCount = raw.entries?.length ?? 0;
} catch {
  /* empty */
}

// Do not use Astro.redirect here: with `site` set (e.g. a leftover placeholder),
// static builds can turn this into an absolute https://example.com/... URL.
// A relative meta refresh always stays on the current host.
if (home?.recordType && home?.recordId) {
  const path = `/records/${encodeURIComponent(home.recordType)}/${encodeURIComponent(home.recordId)}/`;
  const html = `<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><meta http-equiv="refresh" content="0;url=${path}"><meta name="robots" content="noindex"><link rel="canonical" href="${path}"><title>Redirecting…</title></head><body><p><a href="${path}">Continue to the player site home.</a></p></body></html>`;
  return new Response(html, {
    status: 200,
    headers: { 'Content-Type': 'text/html; charset=utf-8' },
  });
}
---
<Layout title="Player site">
  <h1 class="record-title">Player site</h1>
  <p class="meta">
    {exportedAt ? `Last export: ${exportedAt}` : 'No export yet — run the RPG Manager exporter.'}
  </p>
  <p>Published records in manifest: <strong>{entryCount}</strong></p>
  <p>
    From the RPG Manager app: <strong>Settings → Player site → Edit manifest</strong>, then run:
  </p>
  <pre
    style="background:#1a1d24;padding:1rem;border-radius:8px;overflow:auto;font-size:0.85rem;border:1px solid var(--border, #333)"
  ><code>dart run player_site_export -- --db &quot;&lt;path&gt;/anvil.db&quot; --out player-site/public/rpg-export</code></pre>
</Layout>
