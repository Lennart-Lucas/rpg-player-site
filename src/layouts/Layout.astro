---
interface Props {
  title: string;
  description?: string;
  /** App-style sidebar (Home + The World → Locations). */
  shell?: boolean;
  /** Current URL path for active nav (pass `Astro.url.pathname`). */
  shellPath?: string;
}
const {
  title,
  description = 'Player reference',
  shell = false,
  shellPath = '',
} = Astro.props;

function normPath(p: string): string {
  const t = p.trim();
  if (!t || t === '/') return '/';
  return t.replace(/\/+$/, '') || '/';
}
const here = normPath(shellPath);
const homeHref = '/';
const locationsHref = '/world/locations';
const homeActive = here === '/';
const locationsActive =
  here === normPath(locationsHref) ||
  here.startsWith('/records/location/') ||
  here.startsWith('/records/location');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        color-scheme: dark light;
        --bg: #0f1115;
        --fg: #e8eaed;
        --muted: #9aa0a6;
        --link: #8ab4f8;
        --border: #3c4043;
        --sidebar-bg: #161922;
        --sidebar-active: rgba(138, 180, 248, 0.16);
      }
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.55;
      }
      .shell-root {
        display: flex;
        min-height: 100vh;
        align-items: stretch;
      }
      .shell-sidebar {
        flex: 0 0 280px;
        max-width: 100%;
        box-sizing: border-box;
        background: var(--sidebar-bg);
        border-right: 1px solid var(--border);
        padding: 1rem 0.75rem;
      }
      .shell-brand {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        padding: 0.25rem 0.75rem 1rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 0.75rem;
      }
      .shell-nav {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }
      .shell-nav-section-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
        padding: 0.75rem 0.75rem 0.35rem;
        margin-top: 0.25rem;
      }
      .shell-nav-link {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.5rem 0.75rem;
        border-radius: 8px;
        color: var(--fg);
        text-decoration: none;
        font-size: 0.95rem;
      }
      .shell-nav-link:hover {
        background: rgba(255, 255, 255, 0.06);
      }
      .shell-nav-link.active {
        background: var(--sidebar-active);
        color: var(--link);
        font-weight: 600;
      }
      .shell-nav-icon {
        flex: 0 0 auto;
        width: 1.125rem;
        height: 1.125rem;
        color: var(--muted);
      }
      .shell-nav-link.active .shell-nav-icon {
        color: var(--link);
      }
      .shell-main {
        flex: 1 1 auto;
        min-width: 0;
        padding: 1.5rem 1rem 3rem;
        max-width: 52rem;
      }
      .shell-main-wide {
        max-width: none;
      }
      main:not(.shell-main) {
        max-width: 52rem;
        margin: 0 auto;
        padding: 1.5rem 1rem 3rem;
      }
      a {
        color: var(--link);
      }
      .record-title {
        margin: 0 0 0.25rem;
        font-size: 1.75rem;
      }
      .meta {
        margin: 0 0 1.5rem;
        color: var(--muted);
        font-size: 0.9rem;
      }
      .block h2 {
        margin: 1.5rem 0 0.5rem;
        font-size: 1.1rem;
        color: var(--muted);
        font-weight: 600;
      }
      .prose :global(.unpublished-ref) {
        opacity: 0.75;
        text-decoration: underline dotted;
      }
      .empty {
        color: var(--muted);
      }
      @media (max-width: 720px) {
        .shell-root {
          flex-direction: column;
        }
        .shell-sidebar {
          flex: 0 0 auto;
          width: 100%;
          border-right: none;
          border-bottom: 1px solid var(--border);
        }
      }
    </style>
  </head>
  <body>
    {
      shell ? (
        <div class="shell-root">
          <aside class="shell-sidebar">
            <div class="shell-brand">Player site</div>
            <nav class="shell-nav" aria-label="Main">
              <a
                href={homeHref}
                class:list={['shell-nav-link', { active: homeActive }]}
              >
                <svg
                  class="shell-nav-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                  <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
                <span>Home</span>
              </a>
              <div class="shell-nav-section-label">The World</div>
              <a
                href={locationsHref}
                class:list={['shell-nav-link', { active: locationsActive }]}
              >
                <svg
                  class="shell-nav-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
                <span>Locations</span>
              </a>
            </nav>
          </aside>
          <main class="shell-main shell-main-wide">
            <slot />
          </main>
        </div>
      ) : (
        <main>
          <slot />
        </main>
      )
    }
  </body>
</html>
