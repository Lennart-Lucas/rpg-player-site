---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Player reference' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        color-scheme: dark light;
        --bg: #0f1115;
        --fg: #e8eaed;
        --muted: #9aa0a6;
        --link: #8ab4f8;
        --border: #3c4043;
      }
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.55;
      }
      main {
        max-width: 52rem;
        margin: 0 auto;
        padding: 1.5rem 1rem 3rem;
      }
      a {
        color: var(--link);
      }
      .record-title {
        margin: 0 0 0.25rem;
        font-size: 1.75rem;
      }
      .meta {
        margin: 0 0 1.5rem;
        color: var(--muted);
        font-size: 0.9rem;
      }
      .block h2 {
        margin: 1.5rem 0 0.5rem;
        font-size: 1.1rem;
        color: var(--muted);
        font-weight: 600;
      }
      .prose :global(.unpublished-ref) {
        opacity: 0.75;
        text-decoration: underline dotted;
      }
      .empty {
        color: var(--muted);
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
